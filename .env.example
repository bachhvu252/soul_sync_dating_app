# ============================================================
# SoulSync — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ============================================================

# ----- Node.js Backend -----
NODE_ENV=development
PORT=3001
DATABASE_URL=sqlite:./soulsync.db
JWT_SECRET=change_me_256_bit_random_string
JWT_REFRESH_SECRET=change_me_another_256_bit_random_string

# Media storage: "local" | "s3" | "cloudinary"
MEDIA_STORAGE=local
UPLOADS_DIR=./uploads

# Frontend origin (for CORS whitelist)
FRONTEND_ORIGIN=http://localhost:5173

# FastAPI and Flask base URLs (used by Node when proxying)
FASTAPI_BASE_URL=http://localhost:8001
FLASK_BASE_URL=http://localhost:5001

# Shared internal secret for service-to-service calls
INTERNAL_API_SECRET=change_me_internal_secret

# ----- Flask Media Service -----
FLASK_PORT=5001
STORAGE_BACKEND=local   # local | s3 | cloudinary

# AWS S3 (only needed when STORAGE_BACKEND=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1

# Cloudinary (only needed when STORAGE_BACKEND=cloudinary)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ----- FastAPI AI Service -----
FASTAPI_PORT=8001
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# OpenAI (optional — for conversation starters via GPT)
# OPENAI_API_KEY=

# ----- Production Overrides -----
# DATABASE_URL=postgresql://user:pass@host:5432/soulsync
# REDIS_URL=redis://host:6379
